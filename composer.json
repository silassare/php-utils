{
	"name": "silassare/php-utils",
	"description": "PHP utils: a set of php utilities used across projects.",
	"version": "2.0.0",
	"keywords": [
		"php",
		"utilities",
		"utils"
	],
	"require": {
		"php": ">=8.1",
		"ext-json": "*",
		"psr/http-message": "^2.0"
	},
	"require-dev": {
		"roave/security-advisories": "dev-latest",
		"oliup/oliup-cs-php": "dev-main",
		"phpunit/phpunit": "^9.5.26",
		"vimeo/psalm": "^6.0"
	},
	"repositories": {
		"oliup/oliup-cs-php": {
			"type": "vcs",
			"url": "https://github.com/oliup-io/oliup-cs-php"
		}
	},
	"homepage": "https://github.com/silassare/php-utils#readme",
	"archive": {
		"exclude": [
			"/tests"
		]
	},
	"autoload": {
		"psr-4": {
			"PHPUtils\\": "src",
			"PHPUtils\\Tests\\": "tests"
		}
	},
	"authors": [
		{
			"name": "Emile Silas Sare",
			"homepage": "https://github.com/silassare"
		}
	],
	"license": "MIT",
	"minimum-stability": "dev",
	"prefer-stable": true,
	"extra": {
		"branch-alias": {
			"dev-main": "2.x-dev"
		}
	},
	"config": {
		"platform": {
			"php": "8.1.31"
		},
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": false
		}
	}
}
